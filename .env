###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=cbae2066073eeaa00d198fa6f55d48e5
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://root:@db:3306/fund_transfer?serverVersion=8.0.0&charset=utf8mb4"

REDIS_URL=redis://redis:6379
###< Redis ###

###> Rate Limiting ###
# Max transfer requests per minute per IP
RATE_LIMIT_TRANSFER=60
###< Rate Limiting ###

###> Transfer Limits ###
# Default daily transfer limit (fallback if currency not in DAILY_LIMIT_BY_CURRENCY)
DAILY_TRANSFER_LIMIT=50000.0000
# Per-currency daily limits (JSON). Example: {"USD":"50000.0000","INR":"500000.0000","EUR":"45000.0000"}
DAILY_LIMIT_BY_CURRENCY={}
# Timezone for daily velocity window (regulatory jurisdiction). Examples: America/New_York, Asia/Kolkata
DAILY_LIMIT_TIMEZONE=UTC
# Per-transaction max amount (default fallback)
MAX_TRANSACTION_AMOUNT=100000.0000
# Per-currency max transaction amounts (JSON). Example: {"USD":"100000.0000","INR":"1000000.0000"}
MAX_AMOUNT_BY_CURRENCY={}
# Minimum transaction amount (prevents fee arbitrage via micro-transactions)
MIN_TRANSACTION_AMOUNT=0.1000
###< Transfer Limits ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/lock ###
# IMPORTANT: Use redis:// in production for distributed locking across multiple nodes.
# flock only works on a single host and is unsafe in multi-node deployments.
# See .env.docker.example for the production-ready value.
LOCK_DSN=redis://redis:6379
###< symfony/lock ###
